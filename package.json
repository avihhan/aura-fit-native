{
  "name": "aura-fit-native",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eas:build:android": "eas build --platform android --profile production",
    "eas:build:ios": "eas build --platform ios --profile production",
    "eas:build:all": "eas build --platform all --profile production",
    "eas:submit:android": "eas submit --platform android --latest",
    "eas:submit:ios": "eas submit --platform ios --latest"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eas-cli": "^16.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
